# Server
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/dbname
JWT_SECRET=replace_with_long_random_secret
PORT=5000

# Public URL (for links in emails)
PUBLIC_APP_URL=http://localhost:3000

# Email (simple)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# Optional override sender address:
# EMAIL_FROM="NexByte" <your_email@gmail.com>

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Automations
AUTOMATION_ENABLED=true
AUTOMATION_TIMEZONE=Asia/Kolkata
AUTOMATION_SECRET=replace_with_long_random_secret

# Cloudinary (resume uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
